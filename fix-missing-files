```javascript
import React from 'react';
import { useExpense } from '../context/ExpenseContext';

const History = () => {
  const { expenses, categories, deleteExpense } = useExpense();

  const getCategoryEmoji = (categoryName) => {
    const category = categories.find(cat => cat.name === categoryName);
    return category ? category.emoji : '📝';
  };

  const handleDelete = async (expenseId) => {
    if (window.confirm('Are you sure you want to delete this expense?')) {
      await deleteExpense(expenseId);
    }
  };

  return (
    <div style={{ padding: '2rem' }}>
      <h1 style={{ color: '#ffffff', marginBottom: '2rem' }}>Expense History</h1>
      
      <div style={{ display: 'flex', flexDirection: 'column', gap: '1rem' }}>
        {expenses.length === 0 ? (
          <div style={{ textAlign: 'center', padding: '3rem', color: '#888', fontStyle: 'italic' }}>
            No expenses found.
          </div>
        ) : (
          expenses.map(expense => (
            <div key={expense.id} style={{
              backgroundColor: '#2d2d2d',
              borderRadius: '12px',
              padding: '1.5rem',
              border: '1px solid #404040',
              display: 'flex',
              alignItems: 'center',
              gap: '1rem'
            }}>
              <div style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', minWidth: '80px' }}>
                <span style={{ fontSize: '1.5rem', marginBottom: '0.2rem' }}>
                  {getCategoryEmoji(expense.category)}
                </span>
                <span style={{ fontSize: '0.8rem', color: '#cccccc' }}>{expense.category}</span>
              </div>
              
              <div style={{ flex: 1 }}>
                <h3 style={{ color: '#ffffff', margin: '0 0 0.5rem 0' }}>{expense.title}</h3>
                {expense.description && (
                  <p style={{ color: '#cccccc', fontSize: '0.9rem', margin: '0 0 0.5rem 0' }}>
                    {expense.description}
                  </p>
                )}
                <div style={{ fontSize: '0.8rem', color: '#888' }}>
                  {new Date(expense.date).toLocaleDateString()}
                </div>
              </div>
              
              <div style={{ fontSize: '1.3rem', fontWeight: 'bold', color: '#20B2AA', minWidth: '120px', textAlign: 'right' }}>
                ₹{expense.amount.toLocaleString()}
              </div>
              
              <div style={{ minWidth: '80px' }}>
                <button 
                  onClick={() => handleDelete(expense.id)}
                  style={{
                    padding: '0.5rem 1rem',
                    backgroundColor: '#ff4444',
                    color: 'white',
                    border: 'none',
                    borderRadius: '6px',
                    cursor: 'pointer'
                  }}
                >
                  Delete
                </button>
              </div>
            </div>
          ))
        )}
      </div>
    </div>
  );
};

export default History;
